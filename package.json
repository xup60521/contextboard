{
  "name": "contextboard",
  "private": true,
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@contextboard/web",
    "build": "turbo run build",
    "test": "turbo run test",
    "check": "turbo run check",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "deploy": "turbo run deploy --filter=@contextboard/web",
    "generate-routes": "turbo run generate-routes --filter=@contextboard/web",
    "export:convex": "bun run --filter @contextboard/convex-export export"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "turbo": "^2.5.8",
    "typescript": "^6.0.2"
  }
}
