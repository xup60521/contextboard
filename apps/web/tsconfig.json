{
  "extends": "../../tsconfig.base.json",
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "noImplicitAny": false,
    "paths": {
      "#/*": ["./src/*"],
      "@/*": ["./src/*"]
    },
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["vite/client"]
  }
}
